{
  "description": "Agentes especializados para el proyecto CardSystem",
  "version": "1.0.0",
  "agents": [
    {
      "id": "inventory-expert",
      "name": "Experto en Inventario",
      "trigger": "Cuando se trabaje con balance, capturas, movimientos o stock",
      "context": [
        "El balance tiene 4 áreas: Almacén (bóveda trabajo + principal), En Proceso, Logística (colocación + normal + devoluciones), Sucursales (colocación + stock)",
        "Las capturas actualizan el balance en tiempo real via inventoryStore",
        "Los movimientos se registran automáticamente en historial",
        "Datos centralizados en src/data/mockData.ts"
      ],
      "files": [
        "src/stores/inventoryStore.ts",
        "src/data/mockData.ts",
        "src/app/(dashboard)/balance/page.tsx",
        "src/app/(dashboard)/capturas/*/page.tsx"
      ]
    },
    {
      "id": "security-expert",
      "name": "Experto en Seguridad",
      "trigger": "Cuando se trabaje con autenticación, tokens, CSRF, rate limiting o auditoría",
      "context": [
        "Tokens almacenados en httpOnly cookies (no localStorage)",
        "Rate limiting: 5 intentos/min, bloqueo 5 min",
        "CSRF: Double Submit Cookie pattern",
        "Sanitización XSS en todos los inputs",
        "Audit logging para acciones críticas"
      ],
      "files": [
        "src/lib/security/rateLimit.ts",
        "src/lib/security/csrf.ts",
        "src/lib/security/sanitize.ts",
        "src/lib/security/auditLog.ts",
        "src/app/api/auth/login/route.ts",
        "src/app/api/auth/csrf/route.ts"
      ]
    },
    {
      "id": "testing-expert",
      "name": "Experto en Testing",
