      "files": [
        "jest.config.js",
        "jest.setup.js",
        "playwright.config.ts",
        "src/__tests__/**/*"
      ],
      "commands": {
        "runTests": "npm test",
        "runCoverage": "npm run test:coverage",
        "runE2E": "npm run e2e",
        "runE2EUI": "npm run e2e:ui"
      }
    },
    {
