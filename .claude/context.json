{
  "project": {
    "name": "CardSystem",
    "fullName": "Sistema de Inventario de Tarjetas Bancarias",
    "version": "0.1.0",
    "description": "Sistema white-label para gestión de inventario de tarjetas bancarias con forecasting, multi-tenant y control por roles",
    "repository": null,
    "license": "Proprietary"
  },
  "stack": {
    "frontend": {
      "framework": "Next.js 16.1.4",
      "ui": "React 19.2.3",
      "language": "TypeScript 5",
      "styling": "Tailwind CSS 4",
      "stateManagement": "Zustand 5.0.10",
      "dataFetching": "@tanstack/react-query 5.90.19",
      "charts": "Recharts 3.6.0",
      "icons": "Lucide React",
      "exports": ["xlsx", "jspdf", "jspdf-autotable"]
    },
    "backend": {
      "orm": "Prisma 7.3.0",
      "database": "SQLite (via @libsql/client)",
      "auth": ["bcrypt", "jsonwebtoken", "speakeasy (2FA)"],
      "monitoring": "@sentry/nextjs"
    },
    "testing": {
      "unit": "Jest 30.2.0",
      "e2e": "Playwright 1.57.0",
      "utilities": ["@testing-library/react", "@testing-library/jest-dom"]
    }
  },
  "architecture": {
    "pattern": "Next.js App Router",
    "routeGroups": {
      "(auth)": "Autenticación - /login",
      "(dashboard)": "Dashboard protegido - todas las rutas principales"
    },
    "modules": [
      { "name": "Dashboard", "route": "/dashboard", "description": "Vista general y estadísticas" },
      { "name": "Balance", "route": "/balance", "description": "Estado actual del inventario" },
      { "name": "Forecast", "route": "/forecast", "description": "Proyecciones y alertas" },
      { "name": "Captura Almacén", "route": "/capturas/almacen", "description": "Registro inventario central" },
      { "name": "Captura Logística", "route": "/capturas/logistica", "description": "Registro en distribución" },
      { "name": "Captura Sucursales", "route": "/capturas/sucursales", "description": "Registro en puntos de venta" },
      { "name": "Órdenes", "route": "/ordenes", "description": "Gestión de compras" },
      { "name": "Productos", "route": "/productos", "description": "Catálogo de productos" },
      { "name": "Usuarios", "route": "/usuarios", "description": "Administración de usuarios" },
      { "name": "Historial", "route": "/historial", "description": "Log de movimientos" }
    ],
    "stores": {
      "inventoryStore": "src/stores/inventoryStore.ts - Balance, historial, órdenes",
      "userStore": "src/stores/userStore.ts - CRUD usuarios",
      "productStore": "src/stores/productStore.ts - CRUD productos"
    },
    "security": {
      "location": "src/lib/security/",
      "modules": ["rateLimit.ts", "csrf.ts", "sanitize.ts", "auditLog.ts"]
    }
  },
  "database": {
    "provider": "sqlite",
    "mcpServer": "sqlite (global en ~/.claude.json)",
    "connectionPath": "/Users/Marx/Projects/sistema-tarjetas/dev.db",
    "models": [
      "User",
      "AuditLog",
      "RateLimit",
      "Producto",
      "BalanceProducto",
      "Captura",
      "MovimientoHistorial",
      "OrdenCompra",
      "ForecastProducto"
    ],
    "location": "dev.db",
    "note": "Este proyecto usa SQLite. Para proyectos PostgreSQL/PostGIS ver AgroRentable."
  },
  "roles": [
    { "id": "admin", "area": "Administración", "access": "Todos los módulos" },
    { "id": "almacen", "alias": "tsys", "area": "Almacén Central", "access": "Dashboard, Balance, Captura Almacén" },
