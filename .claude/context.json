  "knownIssues": [
    {
      "id": "DOCKER-001",
      "severity": "resolved",
      "description": "Prisma CLI no disponible en runtime de Docker",
      "solution": "Usar template DB pre-creada durante build",
      "learned": "2026-01-23"
    },
    {
      "id": "ENTRYPOINT-001",
      "severity": "resolved",
      "description": "docker-entrypoint.sh usaba sintaxis bash en sh",
      "solution": "Reescrito con sintaxis sh pura",
      "learned": "2026-01-23"
    },
    {
      "id": "SESSION-001",
      "severity": "resolved",
      "description": "Session route intentaba conectar a backend externo inexistente (localhost:8000)",
      "solution": "Modificado para verificar JWT localmente con verifyAccessToken",
      "learned": "2026-01-23"
    },
    {
      "id": "COOKIES-001",
      "severity": "resolved",
      "description": "Cookies con Secure:true no funcionan en HTTP localhost",
      "solution": "Agregado ALLOW_HTTP_COOKIES=true en docker-compose.yml para desactivar Secure flag en desarrollo",
      "learned": "2026-01-23"
    },
    {
      "id": "THEME-001",
      "severity": "resolved",
      "description": "ThemeSelector menu quedaba detrás del sidebar (z-index)",
      "solution": "Usar createPortal para renderizar el menu en document.body con z-index:9999",
      "learned": "2026-01-23"
    }
  ],

